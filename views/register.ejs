<%- include("partials/header") %>

<link rel="stylesheet" href="/register/css/kojo.css">

<header class="header" style="padding: 20px; height: 40px;">
  <div class="logo" style="height: 100%;">
    <a href="/"><img src="/register/images/logo.png" alt="Logo" style="height: 100%;"></a>
  </div>
</header>

<div class="switcher">
  <button id="signup-btn" class="active">Sign In</button>
  <button id="signin-btn">Sign Up</button>
</div>

<div id="feedback-message" class="hidden"></div>

<!-- SIGN UP -->
<div id="signup-form" class="form-container hidden">
  <h2>Create Free Account</h2>
  <form id="signupForm">
    <input type="text" name="fullname" placeholder="Full Name" required>
    <input type="email" name="email" placeholder="Email" required>
    <input type="text" name="username" placeholder="Public Username" required>
    <input type="password" name="password" placeholder="Password" required>
    <input type="password" name="confirm-password" placeholder="Confirm Password" required>

    <select name="country" required>
      <option value="" disabled selected>Country/Region</option>
      <option value="gh">Ghana</option>
      <option value="ng">Nigeria</option>
      <option value="ke">Kenya</option>
      <option value="za">South Africa</option>
      <!-- keep others -->
    </select>

    <div class="terms">
      <input style="width:20px;" type="checkbox" required>
      <label style="font-size: small;">I agree with terms and conditions</label>
    </div>

    <button type="submit">Sign Up</button>
  </form>
</div>

<!-- SIGN IN -->
<div id="signin-form" class="form-container">
  <h2>Sign In</h2>
  <form id="signinForm">
    <input type="text" name="email" placeholder="Email" required>
    <input type="password" name="password" placeholder="Password" required>
    <button type="submit">Sign In</button>
  </form>

  <div class="forgot-password">
    <p><a href="#" id="forgot-password-link">Forgot Password?</a></p>
  </div>

  <div id="forgot-password-form" class="form-container hidden">
    <h2>Forgot Password</h2>
    <form id="forgotPasswordForm">
      <input type="email" name="email" placeholder="Enter your email" required>
      <button type="submit">Send Reset Link</button>
    </form>
  </div>
</div>

<script src="/register/js/kojo.js"></script>

<%- include("partials/footer") %>