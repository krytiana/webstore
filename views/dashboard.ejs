<%- include("partials/header") %>
  

  <link rel="stylesheet" href="/css/dashboard.css">

  <section class="dashboard">
    <div class="top-bar">
      <h1>Welcome, <%= user.username || user.email %></h1>
      <a href="/api/auth/logout" class="logout-btn">Logout</a>
    </div>
    
    <h4>Your Downloads</h4>

    <% if (downloads.length > 0) { %>

      <% downloads.forEach(download => { 
        const isExpired = new Date(download.expiresAt) < new Date();
        const canDownload = !isExpired && download.successfulDownloads < download.maxDownloads;
      %>

        <div class="card">
          <h2><%= download.product.name %></h2>

          <% if (download.product.media?.image) { %>
            <img src="<%= download.product.media.image %>" width="150">
          <% } %>

          <p><strong>Plan:</strong> <%= download.plan %></p>
          <p><strong>Downloads:</strong> <%= download.successfulDownloads %> / <%= download.maxDownloads %></p>
          <p><strong>Expires:</strong> <%= new Date(download.expiresAt).toLocaleString() %></p>

          <% if (canDownload) { %>
            <a href="<%= download.url %>" class="download-btn">Download</a>
          <% } else { %>
            <p class="blocked">Download not available</p>
          <% } %>

        </div>

      <% }); %>

    <% } else { %>
      <p>No downloads found.</p>
    <% } %>

  </section>

  <%- include("partials/footer") %>
