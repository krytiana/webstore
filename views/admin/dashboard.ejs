<%- include("../partials/header") %>

<link rel="stylesheet" href="/css/admin-wizard.css" />

<form id="productForm" action="/admin/add-product" method="POST">

  <!-- STEP 1: Basic Info -->
  <section class="step active">
    <h2>Basic Information</h2>

    <input type="text" name="name" placeholder="Product name" required maxlength="100" />

    <label>
      Category
      <select name="category" required>
        <option value="">Select category</option>
        <option value="Business">Business</option>
        <option value="Portfolio">Portfolio</option>
        <option value="E-commerce">E-commerce</option>
        <option value="Blog">Blog</option>
        <option value="Education">Education</option>
        <option value="Landing Page">Landing Page</option>
        <option value="SaaS">SaaS</option>
        <option value="Other">Other (type manually)</option>
      </select>
    </label>

    <input 
      type="text" 
      name="customCategory" 
      placeholder="Type custom category" 
      style="display:none;"
      maxlength="50"
    />

    <textarea name="description" placeholder="Short description" maxlength="500"></textarea>

    <button type="button" class="next">Next</button>
  </section>

  <!-- STEP 2: Features -->
  <section class="step">
    <h2>Features</h2>

    <h3>🖥️ Frontend Includes</h3>
    <div class="checkbox-group">
      <label><input type="checkbox" name="frontendFeatures[]" value="Responsive UI" checked /> Responsive UI</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="Homepage" checked /> Homepage</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="About page" checked /> About page</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="Services page" checked /> Services page</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="Contact page" checked /> Contact page</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="Login page" checked /> Login page</label>
      <label><input type="checkbox" name="frontendFeatures[]" value="SEO-friendly structure" checked /> SEO-friendly structure</label>
    </div>

    <h3>⚙️ Backend Includes</h3>
    <div class="checkbox-group">
      <label><input type="checkbox" name="backendFeatures[]" value="Admin dashboard" checked /> Admin dashboard</label>
      <label><input type="checkbox" name="backendFeatures[]" value="Secure login system" checked /> Secure login system</label>
      <label><input type="checkbox" name="backendFeatures[]" value="Database integration" checked /> Database integration</label>
      <label><input type="checkbox" name="backendFeatures[]" value="Contact form storage" checked /> Contact form storage</label>
      <label><input type="checkbox" name="backendFeatures[]" value="Product/content management" checked /> Product/content management</label>
      <label><input type="checkbox" name="backendFeatures[]" value="Role-based access (admin)" checked /> Role-based access (admin)</label>
    </div>

    <h3>🛠️ Tech Stack</h3>
    <input type="text" name="techStack" placeholder="e.g. Node.js, Express, MongoDB, EJS" />

    <button type="button" class="prev">Back</button>
    <button type="button" class="next">Next</button>
  </section>

  <!-- STEP 3: Pricing -->
  <section class="step">
    <h2>Pricing</h2>

    <label>
      Pricing Card Type
      <select name="pricingCardType" required>
        <option value="static">Static Website</option>
        <option value="complex">Complex Website</option>
      </select>
    </label>

    <input type="number" name="priceSource" placeholder="SOURCE CODE – Price ($)" min="0" required />
    <input type="number" name="priceAssisted" placeholder="ASSISTED SETUP – Price ($)" min="0" required />
    <input type="number" name="priceDone" placeholder="DONE-FOR-YOU – Price ($)" min="0" required />

    <button type="button" class="prev">Back</button>
    <button type="button" class="next">Next</button>
  </section>

  <!-- STEP 4: Media -->
  <section class="step">
    <h2>Media</h2>

    <input type="text" name="imageFolder" placeholder="Image folder (e.g business-site)" required maxlength="50" />
    <input type="text" name="imageName" placeholder="Image file name (e.g homepage.jpg)" required maxlength="50" />
    <input type="text" name="demoFolder" placeholder="Demo folder name (e.g business-site)" maxlength="50" />

    <button type="button" class="prev">Back</button>
    <button type="submit">Publish Product</button>
  </section>

</form>

<script src="/js/admin-wizard.js"></script>
<%- include("../partials/footer") %>
